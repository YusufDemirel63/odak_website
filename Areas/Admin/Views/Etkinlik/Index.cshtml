@model List<Etkinlik>
@{
    ViewData["Title"] = "Etkinlikler";
}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-calendar-alt" style="color:var(--admin-accent);"></i> Etkinlik Listesi</h3>
        <a asp-action="Ekle" class="btn-admin btn-admin-primary"><i class="fas fa-plus"></i> Yeni Etkinlik</a>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead>
                <tr><th>Başlık</th><th>Tarih</th><th>Konum</th><th>Durum</th><th>İşlem</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td><strong>@e.Baslik</strong></td>
                        <td>@(e.Tarih?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td>@(e.Konum ?? "-")</td>
                        <td><span class="@(e.Aktif ? "badge-aktif" : "badge-pasif")">@(e.Aktif ? "Aktif" : "Pasif")</span></td>
                        <td style="display:flex; gap:8px;">
                            <a asp-action="Duzenle" asp-route-id="@e.Id" class="btn-admin btn-admin-edit"><i class="fas fa-edit"></i></a>
                            <form asp-action="Sil" method="post" style="display:inline;" onsubmit="return confirm('Silinsin mi?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id">
                                <button type="submit" class="btn-admin btn-admin-delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
