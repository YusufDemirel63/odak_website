@model Etkinlik
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Etkinlik" : "Etkinlik Duzenle";
    var isEdit = Model.Id != 0;
}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-calendar-plus" style="color:var(--admin-accent);"></i> @ViewData["Title"]</h3>
        <a asp-action="Index" class="btn-admin btn-admin-edit"><i class="fas fa-arrow-left"></i> Geri</a>
    </div>
    <form asp-action="@(isEdit ? "Duzenle" : "Ekle")" method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom:15px; padding:10px; background:#ffebee; color:#c62828; border-radius:5px;"></div>
        @if (isEdit) { <input type="hidden" asp-for="Id"> <input type="hidden" asp-for="OlusturulmaTarihi"> }
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:20px;">
            <div class="form-group">
                <label>Başlık *</label>
                <input asp-for="Baslik" placeholder="Etkinlik adi">
                <span asp-validation-for="Baslik" style="color:red;font-size:0.8rem;"></span>
            </div>
            <div class="form-group">
                <label>Tarih</label>
                <input asp-for="Tarih" type="date">
            </div>
            <div class="form-group">
                <label>Saat</label>
                <input asp-for="Saat" placeholder="19:30 - 21:30">
            </div>
            <div class="form-group">
                <label>Konum</label>
                <input asp-for="Konum" placeholder="Etkinlik yeri">
            </div>
        </div>
        <div class="form-group">
            <label>Açıklama</label>
            <textarea asp-for="Aciklama" placeholder="Etkinlik aciklamasi..."></textarea>
        </div>
        <div class="form-group">
            <label>Afiş Görseli</label>
            <input type="file" name="afisFile" accept="image/*">
            @if (!string.IsNullOrEmpty(Model.AfisGorseli))
            {
                <div style="margin-top:10px;"><img src="@Model.AfisGorseli" style="height:80px; border-radius:6px;"> <small style="color:#6c757d;">Mevcut gorsel</small></div>
                <input type="hidden" asp-for="AfisGorseli">
            }
        </div>
        <div class="form-group" style="display:flex; align-items:center; gap:10px;">
            <input asp-for="Aktif" type="checkbox" style="width:auto; margin:0;">
            <label asp-for="Aktif" style="margin:0;">Aktif</label>
        </div>
        <button type="submit" class="btn-admin btn-admin-primary" style="padding:12px 30px; font-size:1rem;">
            <i class="fas fa-save"></i> @(isEdit ? "Güncelle" : "Kaydet")
        </button>
    </form>
</div>

