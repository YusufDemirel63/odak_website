@model SliderGorseli
@{ViewData["Title"] = "Slider Ekle";}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-image" style="color:var(--admin-accent);"></i> Slider Gorsel Ekle</h3>
        <a asp-action="Index" class="btn-admin btn-admin-edit"><i class="fas fa-arrow-left"></i> Geri</a>
    </div>
    <form asp-action="Ekle" method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
            <div class="form-group"><label>Gorsel Dosyasi *</label><input type="file" name="gorselFile" accept="image/*" required></div>
            <div class="form-group"><label>Baslik (Opsiyonel)</label><input asp-for="Baslik"></div>
            <div class="form-group"><label>Siralama</label><input asp-for="Siralama" type="number" min="0"></div>
        </div>
        <div class="form-group" style="display:flex;align-items:center;gap:10px;"><input asp-for="Aktif" type="checkbox" style="width:auto;margin:0;" checked><label asp-for="Aktif" style="margin:0;">Aktif</label></div>
        <button type="submit" class="btn-admin btn-admin-primary" style="padding:12px 30px;font-size:1rem;"><i class="fas fa-save"></i> Kaydet</button>
    </form>
</div>
