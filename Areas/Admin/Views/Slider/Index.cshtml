@model List<SliderGorseli>
@{ViewData["Title"] = "Slider Yonetimi";}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-images" style="color:var(--admin-accent);"></i> Slider Gorselleri</h3>
        <a asp-action="Ekle" class="btn-admin btn-admin-primary"><i class="fas fa-plus"></i> Gorsel Ekle</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;">
        @foreach(var s in Model){
            <div style="background:#f8f9fa;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                <img src="@s.GorselYolu" style="width:100%;height:140px;object-fit:cover;">
                <div style="padding:12px;">
                    <p style="font-size:0.85rem;margin-bottom:8px;">Sira: @s.Siralama</p>
                    <span class="@(s.Aktif?"badge-aktif":"badge-pasif")">@(s.Aktif?"Aktif":"Pasif")</span>
                    <div style="display:flex;gap:8px;margin-top:10px;">
                        <form asp-action="AktifDegistir" method="post">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@s.Id">
                            <button type="submit" class="btn-admin btn-admin-success" style="font-size:0.75rem;padding:5px 10px;"><i class="fas fa-toggle-on"></i> Degistir</button>
                        </form>
                        <form asp-action="Sil" method="post" onsubmit="return confirm('Silinsin mi?')">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@s.Id">
                            <button type="submit" class="btn-admin btn-admin-delete" style="font-size:0.75rem;padding:5px 10px;"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
