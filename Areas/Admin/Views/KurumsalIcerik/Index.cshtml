@model List<IcerikSayfasi>
@{ViewData["Title"] = "Kurumsal Icerikler";}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-align-left" style="color:var(--admin-accent);"></i> Kurumsal Icerikler</h3>
    </div>
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead><tr><th>Anahtar (Sistem Kod)</th><th>Sayfa Baslik</th><th>Islem</th></tr></thead>
            <tbody>
                @foreach (var i in Model) {
                    <tr>
                        <td><strong>@i.Anahtar</strong></td>
                        <td>@i.Baslik</td>
                        <td>
                            <a asp-action="Duzenle" asp-route-id="@i.Id" class="btn-admin btn-admin-edit"><i class="fas fa-edit"></i> Icerigi Duzenle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
