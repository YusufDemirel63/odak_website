@model List<EkipBirimi>
@{ViewData["Title"] = "Ekip Birimleri";}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-sitemap" style="color:var(--admin-accent);"></i> @ViewData["Title"]</h3>
        <a asp-action="Ekle" class="btn-admin btn-admin-primary"><i class="fas fa-plus"></i> Birim Ekle</a>
    </div>

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger" style="margin:15px; padding:10px; background:#ffebee; color:#c62828; border-radius:5px;">
            @TempData["Hata"]
        </div>
    }

    <table class="admin-table">
        <thead>
            <tr>
                <th>İkon</th>
                <th>Birim Adı</th>
                <th>Kısa Açıklama</th>
                <th>Sıra</th>
                <th>Durum</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model) {
                <tr>
                    <td><i class="@b.Icon" style="font-size:1.2rem;color:var(--admin-accent);"></i></td>
                    <td>@b.Ad</td>
                    <td>@(b.Aciklama??"-")</td>
                    <td>@b.Sira</td>
                    <td><span class="@(b.Aktif?"badge-aktif":"badge-pasif")">@(b.Aktif?"Aktif":"Pasif")</span></td>
                    <td style="display:flex;gap:8px;">
                        <a asp-action="Duzenle" asp-route-id="@b.Id" class="btn-admin btn-admin-edit"><i class="fas fa-edit"></i></a>
                        <form asp-action="Sil" method="post" onsubmit="return confirm('Bu birimi silmek istediğinize emin misiniz? (Bağlı üyeler varsa silinemez)')">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@b.Id">
                            <button type="submit" class="btn-admin btn-admin-delete"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
