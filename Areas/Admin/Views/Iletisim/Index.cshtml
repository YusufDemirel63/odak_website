@model List<IletisimMesaji>
@{ViewData["Title"] = "Mesajlar";}
<div class="admin-card">
    <div class="admin-card-header">
        <h3><i class="fas fa-envelope" style="color:var(--admin-accent);"></i> Iletisim Mesajlari</h3>
    </div>
    <table class="admin-table">
        <thead><tr><th>Ad Soyad</th><th>E-posta</th><th>Tarih</th><th>Durum</th><th>Islem</th></tr></thead>
        <tbody>
            @foreach(var m in Model){
                <tr style="@(!m.Okundu ? "font-weight:600;" : "")">
                    <td>@m.AdSoyad @(!m.Okundu ? "<span class='badge-pasif'>Yeni</span>" : "")</td>
                    <td>@m.Email</td>
                    <td>@m.GonderimTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                    <td><span class="@(m.Okundu?"badge-aktif":"badge-pasif")">@(m.Okundu?"Okundu":"Okunmadi")</span></td>
                    <td style="display:flex;gap:8px;">
                        <a asp-action="Detay" asp-route-id="@m.Id" class="btn-admin btn-admin-edit"><i class="fas fa-eye"></i></a>
                        <form asp-action="Sil" method="post" onsubmit="return confirm('Silinsin mi?')">
                            @Html.AntiForgeryToken()<input type="hidden" name="id" value="@m.Id">
                            <button type="submit" class="btn-admin btn-admin-delete"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
