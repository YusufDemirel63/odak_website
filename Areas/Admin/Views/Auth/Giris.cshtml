@{
    Layout = null;
    ViewData["Title"] = "Admin Giris";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Odak Admin - Giris</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center; background: linear-gradient(135deg, #003054, #f15a39); font-family:'Poppins',sans-serif; }
        .login-card { background:#fff; border-radius:20px; padding:50px 40px; width:100%; max-width:420px; box-shadow:0 20px 60px rgba(0,0,0,0.2); }
        .login-logo { text-align:center; margin-bottom:30px; }
        .login-logo img { height:70px; }
        .login-logo h2 { color:#003054; font-size:1.4rem; margin-top:10px; }
        .login-logo p { color:#6c757d; font-size:0.9rem; }
        .form-group { margin-bottom:20px; }
        .form-group label { display:block; margin-bottom:8px; color:#003054; font-weight:500; font-size:0.9rem; }
        .form-group input { width:100%; padding:14px 16px; border:2px solid #e9ecef; border-radius:10px; font-size:1rem; font-family:inherit; transition:border-color 0.3s; box-sizing:border-box; }
        .form-group input:focus { outline:none; border-color:#f15a39; }
        .btn-login { width:100%; padding:14px; background:#f15a39; color:#fff; border:none; border-radius:10px; font-size:1rem; font-weight:600; cursor:pointer; transition:all 0.3s; font-family:inherit; }
        .btn-login:hover { background:#d4412a; transform:translateY(-2px); box-shadow:0 5px 15px rgba(241,90,57,0.4); }
        .error-msg { background:#fee2e2; color:#dc2626; padding:12px 16px; border-radius:8px; margin-bottom:20px; font-size:0.9rem; }
        .input-icon { position:relative; }
        .input-icon i { position:absolute; right:14px; top:50%; transform:translateY(-50%); color:#6c757d; }
        .input-icon input { padding-right:42px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <img src="/gorseller/OdakLogo.svg" alt="Odak Logo">
            <h2>Admin Paneli</h2>
            <p>Odak Düşünce Kulübü</p>
        </div>
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="error-msg"><i class="fas fa-exclamation-circle"></i> Kullanici adi veya sifre yanlis.</div>
        }
        <form method="post" asp-action="Giris" asp-controller="Auth" asp-area="Admin">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <div class="input-icon">
                    <input type="text" name="kullaniciAdi" placeholder="Kullanici adinizi girin" required autocomplete="username">
                    <i class="fas fa-user"></i>
                </div>
            </div>
            <div class="form-group">
                <label>Şifre</label>
                <div class="input-icon">
                    <input type="password" name="sifre" placeholder="Sifrenizi girin" required autocomplete="current-password">
                    <i class="fas fa-lock"></i>
                </div>
            </div>
            <button type="submit" class="btn-login"><i class="fas fa-sign-in-alt"></i> Giriş Yap</button>
        </form>
    </div>
</body>
</html>
