@model IletisimFormViewModel
@{
    ViewData["Title"] = "Iletisim";
}
<section style="padding: 60px 0; background-color: var(--bg-light);">
    <div class="container">
        <div class="section-title">
            <h2>Bize Ulaşın</h2>
            <p style="margin-top:15px; color:var(--text-muted); font-size:1.1rem;">Soru, görüş ve önerileriniz için aşağıdaki formu doldurabilirsiniz.</p>
        </div>
        @if (TempData["Basarili"] != null)
        {
            <div style="background:#d4edda; color:#155724; padding:15px 20px; border-radius:8px; margin:20px 0; border:1px solid #c3e6cb;">
                <i class="fas fa-check-circle"></i> @TempData["Basarili"]
            </div>
        }
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:40px; margin-top:40px;">
            <div style="background:#fff; padding:40px; border-radius:10px; box-shadow:0 5px 20px rgba(0,0,0,0.05);">
                <h3 style="margin-bottom:25px; color:var(--secondary-color);">İletişim Bilgileri</h3>
                <div style="display:flex; align-items:flex-start; gap:15px; margin-bottom:20px;">
                    <div style="background:var(--primary-color); color:#fff; width:40px; height:40px; border-radius:50%; display:flex; justify-content:center; align-items:center; flex-shrink:0;">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div><h4 style="margin-bottom:5px; color:var(--secondary-color);">Adres</h4><p style="color:var(--text-muted);">Adana, Türkiye</p></div>
                </div>
                <div style="display:flex; align-items:flex-start; gap:15px; margin-bottom:20px;">
                    <div style="background:var(--primary-color); color:#fff; width:40px; height:40px; border-radius:50%; display:flex; justify-content:center; align-items:center; flex-shrink:0;">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div><h4 style="margin-bottom:5px; color:var(--secondary-color);">E-posta</h4>
                    <a href="mailto:odakdusuncekulubu@gmail.com" style="color:var(--text-muted); text-decoration:none;">odakdusuncekulubu@gmail.com</a></div>
                </div>
                <div style="display:flex; align-items:flex-start; gap:15px; margin-bottom:30px;">
                    <div style="background:var(--primary-color); color:#fff; width:40px; height:40px; border-radius:50%; display:flex; justify-content:center; align-items:center; flex-shrink:0;">
                        <i class="fas fa-phone"></i>
                    </div>
                    <div><h4 style="margin-bottom:5px; color:var(--secondary-color);">Telefon</h4>
                    <a href="tel:+905522722563" style="color:var(--text-muted); text-decoration:none;">+90 552 272 25 63</a></div>
                </div>
            </div>
            <div style="background:#fff; padding:40px; border-radius:10px; box-shadow:0 5px 20px rgba(0,0,0,0.05);">
                <form asp-action="Index" asp-controller="Iletisim" method="post">
                    @Html.AntiForgeryToken()
                    <div style="margin-bottom:20px;">
                        <input asp-for="AdSoyad" type="text" placeholder="Adınız Soyadınız *"
                               style="width:100%; padding:15px; border:1px solid #ddd; border-radius:5px; font-family:inherit; font-size:1rem; outline:none;">
                        <span asp-validation-for="AdSoyad" style="color:red; font-size:0.85rem;"></span>
                    </div>
                    <div style="margin-bottom:20px;">
                        <input asp-for="Email" type="email" placeholder="E-posta Adresiniz *"
                               style="width:100%; padding:15px; border:1px solid #ddd; border-radius:5px; font-family:inherit; font-size:1rem; outline:none;">
                        <span asp-validation-for="Email" style="color:red; font-size:0.85rem;"></span>
                    </div>
                    <div style="margin-bottom:20px;">
                        <input asp-for="Telefon" type="tel" placeholder="Telefon Numaranız"
                               style="width:100%; padding:15px; border:1px solid #ddd; border-radius:5px; font-family:inherit; font-size:1rem; outline:none;">
                    </div>
                    <div style="margin-bottom:20px;">
                        <textarea asp-for="Mesaj" placeholder="Mesajınız *" rows="5"
                                  style="width:100%; padding:15px; border:1px solid #ddd; border-radius:5px; font-family:inherit; font-size:1rem; outline:none; resize:vertical;"></textarea>
                        <span asp-validation-for="Mesaj" style="color:red; font-size:0.85rem;"></span>
                    </div>
                    <button type="submit" class="btn-primary" style="width:100%; border:none; cursor:pointer; text-transform:uppercase; font-weight:600; letter-spacing:1px;">Gönder</button>
                </form>
            </div>
        </div>
    </div>
</section>
