@model List<Yayin>
@{
    ViewData["Title"] = "Raporlar";
}
<section style="padding: 60px 0; min-height:60vh; background: var(--bg-light);">
    <div class="container">
        <div class="section-title"><h2>Raporlar</h2></div>
        @if (Model.Any())
        {
            <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:25px; margin-top:30px;">
                @foreach (var yayin in Model)
                {
                    <div style="background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 4px 15px rgba(0,0,0,0.08); transition:transform 0.3s;">
                        @if (!string.IsNullOrEmpty(yayin.GorselYolu))
                        {
                            <img src="@yayin.GorselYolu" alt="@yayin.Baslik" style="width:100%; height:200px; object-fit:cover;">
                        }
                        <div style="padding:20px;">
                            <h3 style="font-size:1rem; font-weight:600; color:var(--secondary-color); margin-bottom:10px;">@yayin.Baslik</h3>
                            @if (yayin.YayinTarihi.HasValue)
                            {
                                <p style="font-size:0.85rem; color:var(--text-muted); margin-bottom:10px;"><i class="fas fa-calendar"></i> @yayin.YayinTarihi.Value.ToString("dd MMMM yyyy")</p>
                            }
                            @if (!string.IsNullOrEmpty(yayin.DosyaYolu))
                            {
                                <a href="@yayin.DosyaYolu" target="_blank" class="btn-secondary" style="font-size:0.85rem; padding:8px 16px;">
                                    <i class="fas fa-download"></i> İndir
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(yayin.DisLink))
                            {
                                <a href="@yayin.DisLink" target="_blank" class="btn-secondary" style="font-size:0.85rem; padding:8px 16px;">
                                    <i class="fas fa-external-link-alt"></i> İncele
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center; padding:60px; color:var(--text-muted);">
                <i class="fas fa-book" style="font-size:4rem; margin-bottom:20px;"></i>
                <p>Henüz Raporlar bulunmamaktadır.</p>
            </div>
        }
    </div>
</section>
