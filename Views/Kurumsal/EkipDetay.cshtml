@model OdakMVC.Models.Entities.EkipUyesi
@{
    ViewData["Title"] = Model.AdSoyad;
}

<style>
    .member-profile-header {
        background: linear-gradient(135deg, var(--secondary-color), #001a33);
        padding: 80px 0 60px;
        color: #fff;
    }
    .profile-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        padding: 40px;
        margin-top: -80px;
        position: relative;
        z-index: 10;
        display: flex;
        gap: 40px;
        align-items: flex-start;
    }
    .profile-img-box {
        flex: 0 0 250px;
        text-align: center;
    }
    .profile-img-box img {
        width: 250px;
        height: 250px;
        border-radius: 20px;
        object-fit: cover;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        border: 4px solid #fff;
        background: #f1f5f9;
    }
    .profile-img-box .ava-placeholder {
        width: 250px;
        height: 250px;
        border-radius: 20px;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
        color: #94a3b8;
        border: 4px solid #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }
    .profile-info {
        flex: 1;
    }
    .profile-info h1 {
        font-size: 2.2rem;
        color: var(--secondary-color);
        margin-bottom: 5px;
        font-weight: 700;
    }
    .profile-info .badge-role {
        display: inline-block;
        background: rgba(241, 90, 57, 0.1);
        color: var(--primary-color);
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 25px;
    }
    .profile-info .badge-unit {
        display: inline-block;
        background: #f1f5f9;
        color: #475569;
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 25px;
        margin-left: 10px;
    }
    .info-list {
        list-style: none;
        padding: 0;
        margin: 0 0 30px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }
    .info-list li {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #475569;
        font-size: 1rem;
    }
    .info-list li i {
        color: var(--primary-color);
        width: 20px;
        text-align: center;
        font-size: 1.1rem;
    }
    .about-section {
        margin-top: 35px;
        padding-top: 35px;
        border-top: 1px solid #e2e8f0;
    }
    .about-section h3 {
        font-size: 1.3rem;
        color: var(--secondary-color);
        margin-bottom: 15px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .about-content {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #334155;
    }
    
    @@media (max-width: 768px) {
        .profile-card {
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 30px 20px;
        }
        .profile-info .badge-unit {
            margin-left: 0;
            margin-top: 10px;
        }
        .info-list li {
            justify-content: center;
        }
    }
</style>

<div class="member-profile-header">
    <div class="container">
        <div style="height: 40px;"></div> <!-- Spacer -->
    </div>
</div>

<div class="container" style="margin-bottom: 80px;">
    <div class="profile-card">
        <div class="profile-img-box">
            @if (!string.IsNullOrEmpty(Model.FotografYolu))
            {
                <img src="@Model.FotografYolu" alt="@Model.AdSoyad">
            }
            else
            {
                <div class="ava-placeholder"><i class="fas fa-user"></i></div>
            }
        </div>
        
        <div class="profile-info">
            <a asp-action="Ekibimiz" style="display:inline-block; margin-bottom:15px; color:#64748b; font-size:0.9rem; text-decoration:none;"><i class="fas fa-arrow-left"></i> Ekibe Dön</a>
            
            <h1>@Model.AdSoyad</h1>
            
            <div>
                @if (!string.IsNullOrEmpty(Model.Gorev))
                {
                    <span class="badge-role">@Model.Gorev</span>
                }
                
                @if (Model.EkipBirimi != null)
                {
                    <span class="badge-unit"><i class="fas fa-users" style="margin-right:6px;"></i>@Model.EkipBirimi.Ad</span>
                }
                else if (Model.HiyerarsiKademesi == 1 || Model.HiyerarsiKademesi == 2 || Model.HiyerarsiKademesi == 3)
                {
                    <span class="badge-unit"><i class="fas fa-crown" style="margin-right:6px; color:#f59e0b;"></i>Yönetim</span>
                }
            </div>

            <ul class="info-list">
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <li><i class="fas fa-envelope"></i> <a href="mailto:@Model.Email" style="color:inherit;">@Model.Email</a></li>
                }
            </ul>

            <div class="about-section">
                <h3><i class="fas fa-id-card" style="color:var(--primary-color);"></i> Hakkında</h3>
                <div class="about-content">
                    @if (!string.IsNullOrEmpty(Model.Hakkinda))
                    {
                        @Html.Raw(Model.Hakkinda.Replace("\n", "<br/>"))
                    }
                    else
                    {
                        <p style="color:#94a3b8; font-style:italic;">Kişi hakkında henüz bir bilgi girilmemiştir.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
