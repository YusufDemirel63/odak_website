@{
    var vizyon = ViewBag.Vizyon as OdakMVC.Models.Entities.IcerikSayfasi;
    var misyon = ViewBag.Misyon as OdakMVC.Models.Entities.IcerikSayfasi;
    ViewData["Title"] = "Vizyon & Misyon";
}
<section class="page-header" style="background: linear-gradient(rgba(0,48,84,0.85), rgba(0,48,84,0.95)), url('/gorseller/sliders/2.png'); background-size:cover; background-position:center; padding: 80px 0; text-align: center;">
    <div class="container">
        <h1 style="color:#fff; font-size: 2.5rem; margin-bottom: 15px;">Vizyon & Misyon</h1>
        <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">Kulübümüzün temel ilkeleri ve varlık gayesi.</p>
    </div>
</section>

<section class="vision-mission" style="padding: 60px 0;">
    <div class="container">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:40px;">
            <div style="background:#fff; padding:40px; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.05);">
                <div style="text-align:center; color:var(--accent-color); font-size:3rem; margin-bottom:20px;">
                    <i class="fas fa-eye"></i>
                </div>
                <h2 style="text-align:center; color:var(--primary-color); margin-bottom:20px;">@(vizyon?.Baslik ?? "Vizyon")</h2>
                <div style="font-size:1.05rem; line-height:1.8; color:var(--text-dark);">
                    @Html.Raw(vizyon?.Icerik?.Replace("\n", "<br/>") ?? "Icerik girilmedi.")
                </div>
            </div>

            <div style="background:#fff; padding:40px; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.05);">
                <div style="text-align:center; color:var(--accent-color); font-size:3rem; margin-bottom:20px;">
                    <i class="fas fa-bullseye"></i>
                </div>
                <h2 style="text-align:center; color:var(--primary-color); margin-bottom:20px;">@(misyon?.Baslik ?? "Misyon")</h2>
                <div style="font-size:1.05rem; line-height:1.8; color:var(--text-dark);">
                    @Html.Raw(misyon?.Icerik?.Replace("\n", "<br/>") ?? "Icerik girilmedi.")
                </div>
            </div>
        </div>
    </div>
</section>
