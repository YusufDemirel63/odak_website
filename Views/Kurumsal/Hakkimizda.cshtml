@model OdakMVC.Models.Entities.IcerikSayfasi
@{
    ViewData["Title"] = Model?.Baslik ?? "Hakkımızda";
    var nedenOdak = ViewBag.NedenOdak as OdakMVC.Models.Entities.IcerikSayfasi;
}
<section class="page-header" style="background: linear-gradient(rgba(0,48,84,0.85), rgba(0,48,84,0.95)), url('@(Model?.GorselYolu ?? "/gorseller/sliders/1.png")'); background-size:cover; background-position:center; padding: 80px 0; text-align: center;">
    <div class="container">
        <h1 style="color:#fff; font-size: 2.5rem; margin-bottom: 15px;">@ViewData["Title"]</h1>
        <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">Zihinsel gelişim ve toplumsal farkındalık... Odak noktası.</p>
    </div>
</section>

<section class="about-content" style="padding: 60px 0;">
    <div class="container">
        @if (Model != null)
        {
            <div style="font-size:1.08rem; line-height:1.9; color:#374151; background:#fff; padding:45px; border-radius:16px; box-shadow:0 8px 30px rgba(0,0,0,0.06); margin-bottom:50px;">
                @Html.Raw(Model.Icerik.Replace("\n", "<br/>"))
            </div>
        }
        else
        {
            <p style="text-align:center; color:#888;">İçerik bulunamadı.</p>
        }
    </div>
</section>

@if (nedenOdak != null)
{
    <section style="padding: 60px 0; background: var(--bg-light);">
        <div class="container">
            <div class="section-title">
                <h2>@(nedenOdak.Baslik ?? "Neden ODAK?")</h2>
            </div>
            <div style="font-size:1.08rem; line-height:1.9; color:#374151; background:#fff; padding:45px; border-radius:16px; box-shadow:0 8px 30px rgba(0,0,0,0.06); margin-top:20px; border-left:5px solid var(--primary-color);">
                @Html.Raw(nedenOdak.Icerik.Replace("\n", "<br/>"))
            </div>
        </div>
    </section>
}
