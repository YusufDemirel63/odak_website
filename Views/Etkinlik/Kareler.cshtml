@model List<GaleriGorseli>
@{
    ViewData["Title"] = "Etkinliklerden Kareler";
}
<section style="padding: 60px 0; min-height: 60vh; background: var(--bg-light);">
    <div class="container">
        <div class="section-title"><h2>Etkinliklerden Kareler</h2></div>
        @if (Model.Any())
        {
            <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:20px; margin-top:30px;">
                @foreach (var gorsel in Model)
                {
                    <div style="border-radius:12px; overflow:hidden; box-shadow:0 4px 15px rgba(0,0,0,0.1); background:#fff;">
                        <img src="@gorsel.GorselYolu" alt="@gorsel.Baslik" style="width:100%; height:220px; object-fit:cover;">
                        @if (!string.IsNullOrEmpty(gorsel.Baslik))
                        {
                            <div style="padding:15px;">
                                <p style="font-weight:500; color:var(--secondary-color);">@gorsel.Baslik</p>
                                @if (!string.IsNullOrEmpty(gorsel.EtkinlikAdi))
                                {
                                    <small style="color:var(--text-muted);">@gorsel.EtkinlikAdi</small>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center; padding: 60px; color: var(--text-muted);">
                <i class="fas fa-images" style="font-size: 4rem; margin-bottom: 20px;"></i>
                <p>Henüz galeri görseli bulunmamaktadır.</p>
            </div>
        }
    </div>
</section>
