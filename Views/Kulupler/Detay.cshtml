@model OdakMVC.Models.Entities.Kulup
@{
    ViewData["Title"] = Model.Ad + " Kulübü";
}
<section class="page-header" style="background: linear-gradient(rgba(0,48,84,0.85), rgba(0,48,84,0.95)), url('@(Model.GorselYolu ?? "/gorseller/sliders/1.png")'); background-size:cover; background-position:center; padding: 80px 0; text-align: center;">
    <div class="container">
        <h1 style="color:#fff; font-size: 2.5rem; margin-bottom: 15px;"><i class="@Model.Icon"></i> @Model.Ad Kulübü</h1>
        <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem;">@Model.KisaAciklama</p>
    </div>
</section>

<section style="padding: 60px 0; min-height: 40vh; background-color: var(--bg-light);">
    <div class="container">
        <div class="features-grid" style="grid-template-columns: 1fr; max-width: 800px; margin: 0 auto; background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
            <div style="font-size: 1.05rem; line-height: 1.8; color: var(--text-dark);">
                @Html.Raw(Model.UzunAciklama?.Replace("\n", "<br/>"))
            </div>
        </div>
        
        <div style="text-align:center; margin-top:40px;">
            <a asp-controller="Home" asp-action="Index" class="btn-secondary"><i class="fas fa-arrow-left"></i> Ana Sayfaya Dön</a>
        </div>
    </div>
</section>
